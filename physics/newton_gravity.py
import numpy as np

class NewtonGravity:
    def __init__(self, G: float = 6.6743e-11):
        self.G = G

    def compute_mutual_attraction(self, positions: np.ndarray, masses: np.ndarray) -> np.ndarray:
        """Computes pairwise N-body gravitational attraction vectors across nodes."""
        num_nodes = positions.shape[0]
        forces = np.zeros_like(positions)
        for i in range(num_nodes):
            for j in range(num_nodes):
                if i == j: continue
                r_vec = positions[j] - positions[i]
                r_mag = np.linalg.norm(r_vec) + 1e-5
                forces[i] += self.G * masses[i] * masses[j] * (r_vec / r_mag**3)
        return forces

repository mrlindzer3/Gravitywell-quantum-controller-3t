# physics/newton_gravity.py
import numpy as np

class NewtonGravity:
    def __init__(self, G: float = 6.6743e-11):
        self.G = G

    def compute_mutual_attraction(self, positions: np.ndarray, masses: np.ndarray) -> np.ndarray:
        """Computes pairwise N-body gravitational attraction vectors across nodes."""
        num_nodes = positions.shape[0]
        forces = np.zeros_like(positions)
        for i in range(num_nodes):
            for j in range(num_nodes):
                if i == j: continue
                r_vec = positions[j] - positions[i]
                r_mag = np.linalg.norm(r_vec) + 1e-5
                forces[i] += self.G * masses[i] * masses[j] * (r_vec / r_mag**3)
        return forces
